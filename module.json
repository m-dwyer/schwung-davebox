{
    "id": "overture",
    "name": "Overture",
    "version": "0.9.0",
    "abbrev": "Overture",
    "description": "Hybrid 8-track sequencer for Ableton Move with Move-native and Schwung/open-engine tracks.",
    "author": "Em Dwyer",
    "api_version": 2,
    "ui": "ui.js",
    "dsp": "dsp.so",
    "component_type": "tool",
    "tool_config": {
        "interactive": true,
        "skip_file_browser": true,
        "overtake": true
    },
    "capabilities": {
        "midi_in": true,
        "midi_out": true,
        "aftertouch": true,
        "button_passthrough": [
            79
        ],
        "claims_master_knob": true,
        "suspend_keeps_js": true
    }
}
