{
  "name": "overture-ui",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "description": "Overture Schwung tool module — C DSP + JS UI. esbuild is the host-only bundler for ui/ui.js -> dist/overture/ui.js (see scripts/bundle_ui.sh).",
  "scripts": {
    "bundle": "scripts/bundle_ui.sh",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@vitest/coverage-v8": "2.1.9",
    "esbuild": "^0.21.5",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  }
}
